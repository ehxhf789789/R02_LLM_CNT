# KIPRIS Plus API
KIPRIS_API_KEY=your_kipris_api_key_here

# ScienceON API (토큰 발급 이슈로 현재 사용 불가)
SCIENCEON_AUTH_KEY=your_scienceon_auth_key_here
SCIENCEON_CLIENT_ID=your_scienceon_client_id_here

# Semantic Scholar API (선택적, 키 없이도 동작 - 100 req/5분)
SEMANTIC_SCHOLAR_API_KEY=

# KCI (한국학술지인용색인) API (data.go.kr에서 발급)
KCI_API_KEY=your_kci_api_key_here

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-multilingual-v3

# Data directories
DATA_DIR=./data
